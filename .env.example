# ---- required ----
# Public hostname; DNS A/AAAA must point at this VPS. Caddy gets a cert for it.
DOMAIN=builder.example.com

# The builder repo the broker dispatches to.
GITHUB_REPO=thingino/thingino-image-builder

# GitHub auth — provide EITHER a token (Option A) OR a GitHub App (Option B).
#
# Option A: a token the broker uses to dispatch builds + manage releases/runs.
#   Fine-grained PAT scoped to GITHUB_REPO: Contents R/W, Actions R/W, Metadata R
#   (thingino's commit is an unauth public read, so no other-repo access needed).
#   A classic PAT with `repo` + `workflow` also works.
GITHUB_TOKEN=github_pat_xxxxxxxx
#
# Option B: a GitHub App installed on GITHUB_REPO (no expiry, org-owned — preferred
#   long-term). Set these THREE instead of GITHUB_TOKEN; the broker mints its own
#   short-lived installation tokens. In a container, mount the key (see the Quadlet
#   unit) and point KEY_PATH at the in-container path.
#GITHUB_APP_ID=123456
#GITHUB_APP_INSTALLATION_ID=12345678
#GITHUB_APP_KEY_PATH=/app/app-key.pem

# ---- admin (run ./setup.sh to generate these) ----
ADMIN_TOKEN=
ADMIN_TOTP_SECRET=
# AES-256-GCM key (base64, 32 bytes: `openssl rand -base64 32`) sealing named admins'
# TOTP seeds in the DB, so a copy of the database can't mint 2FA codes. Optional but
# recommended; existing plaintext seeds re-seal on each admin's next login. KEEP A COPY
# OUTSIDE THE HOST: losing it locks every named admin out of 2FA (master is unaffected).
#TOTP_ENC_KEY=

# ---- optional tuning (defaults shown) ----
#PER_USER_HOURLY_LIMIT=2
#PER_IP_HOURLY_LIMIT=3
#GLOBAL_HOURLY_LIMIT=20
#MAX_CONCURRENT_BUILDS=6
#RETENTION_SECS=1800
# How long a FAILED build keeps its Actions run (and its logs) before the reaper deletes
# it, so an admin still has a working link from the panel to what broke. Default 8h.
#FAILED_RETENTION_SECS=28800
#ROLLING_TAG=web-builds
#THINGINO_REPO=themactep/thingino-firmware
#THINGINO_REF=master
